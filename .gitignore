cat > .gitignore << 'EOF'
# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# MLflow
mlruns/
mlflow.db

# Models & Experiments (حجمشون زیاده)
experiments/
*.pt
*.bin

# Virtual Environment
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db

# pytest
.pytest_cache/
EOF